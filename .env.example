# ============================================
# DocuMind AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ============================================

# --- Supabase ---
# From: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=documents

# --- OpenAI ---
# From: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Inngest (cola asincrona para ingesta) ---
# From: https://app.inngest.com/env/production/manage/keys
# Optional in dev (Inngest dev server runs at http://localhost:8288 without keys)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Upstash Redis (rate limiting) ---
# From: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
